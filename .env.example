# ──────────────────────────────────────────────────────────
# Base de données PostgreSQL — Obligatoire
# ──────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/mmiplace"

# URL directe (optionnel) — bypass un éventuel connection pooler (PgBouncer, Supabase…)
# DATABASE_DIRECT_URL="postgresql://user:password@localhost:5432/mmiplace"

# Pool max de connexions Prisma (optionnel, défaut: 10 en dev, 1 en prod)
# PRISMA_POOL_MAX=10

# ──────────────────────────────────────────────────────────
# Authentik OIDC — Obligatoire pour l'authentification
# ──────────────────────────────────────────────────────────

# URL de base de votre instance Authentik (sans slash final)
AUTHENTIK_ISSUER="https://auth.example.com"

# Client ID & Secret de l'application OIDC créée dans Authentik
AUTHENTIK_CLIENT_ID="mmi-place-client-id"
AUTHENTIK_CLIENT_SECRET="mmi-place-client-secret"

# URL de callback (doit correspondre à celle configurée dans Authentik)
AUTHENTIK_REDIRECT_URI="http://localhost:3000/api/auth/callback"

# Secret pour signer les cookies de session (min 32 caractères)
# Générer avec : openssl rand -hex 32
AUTHENTIK_SESSION_SECRET="generate-a-random-secret-at-least-32-bytes"

# ──────────────────────────────────────────────────────────
# Celcat — Emploi du temps étudiant
# ──────────────────────────────────────────────────────────
CELCAT_URL="https://celcat-back.mmi.codes"
